#include <SPI.h>
#include <LoRa.h>

// Definição explícita dos pinos (Ajuste para a sua placa/montagem)
// Valores comuns para módulos com ESP32 (ex: TTGO LoRa32, Heltec)
#define SCK     5
#define MISO    19
#define MOSI    27
#define SS      18
#define RST     14
#define DIO0    26

void setup() {
  Serial.begin(115200);
  while (!Serial);

  Serial.println("LoRa Receiver");

  // Sobrescreve os pinos padrão do SPI para garantir comunicação
  SPI.begin(SCK, MISO, MOSI, SS);
  LoRa.setPins(SS, RST, DIO0);

  if (!LoRa.begin(915E6)) { // Ajuste a frequência (915E6, 868E6, 433E6) conforme seu módulo
    Serial.println("Starting LoRa failed!");
    
    // CORREÇÃO WDT: O delay(10) alimenta o watchdog do FreeRTOS,
    // permitindo que tarefas de background rodem e evitando o TG1WDT_SYS_RESET.
    while (1) {
      delay(10);
    }
  }
  
  Serial.println("LoRa Inicializado com Sucesso!");
}

void loop() {
  // try to parse packet
  int packetSize = LoRa.parsePacket();
  
  if (packetSize) {
    // received a packet
    Serial.print("Received packet '");

    // read packet
    while (LoRa.available()) {
      Serial.print((char)LoRa.read());
    }

    // print RSSI of packet
    Serial.print("' with RSSI ");
    Serial.println(LoRa.packetRssi());
  }
}
